<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 installer for rat-commander (rc.exe).
  Build:  wix build packaging/windows/rc.wxs -d Version=X.Y.Z -d BinDir=<dir> -o rc.msi
  Installs rc.exe to "Program Files\rat-commander" and adds it to the system PATH.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="rat-commander (rc)"
           Manufacturer="rat-commander"
           Version="$(var.Version)"
           UpgradeCode="7B2A1C3D-4E5F-6A7B-8C9D-0E1F2A3B4C5D"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of rat-commander is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="rat-commander">
        <Component Id="MainExe" Guid="*">
          <File Id="rc.exe" Source="$(var.BinDir)\rc.exe" KeyPath="yes" />
        </Component>
        <!-- `rcedit` shim: `rcedit <file>` == `rc /edit <file>` (start in the
             editor). Shipped from the source tree, not the build dir. -->
        <Component Id="EditShim" Guid="*">
          <File Id="rcedit.cmd" Source="$(sys.SOURCEFILEDIR)rcedit.cmd" KeyPath="yes" />
        </Component>
        <Component Id="PathEnv" Guid="9F8E7D6C-5B4A-3210-FEDC-BA9876543210">
          <CreateFolder />
          <Environment Id="UpdatePath"
                       Name="PATH"
                       Value="[INSTALLFOLDER]"
                       Permanent="no"
                       Part="last"
                       Action="set"
                       System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="rat-commander" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="EditShim" />
      <ComponentRef Id="PathEnv" />
    </Feature>
  </Package>
</Wix>
